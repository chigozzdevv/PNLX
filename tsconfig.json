{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./server/src/*"
      ]
    },
    "skipLibCheck": true,
    "strict": true,
    "types": [
      "bun"
    ]
  },
  "include": [
    "server/src/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "client",
    "node_modules"
  ]
}
